    "    \"   \\\"cell_type\\\": \\\"code\\\",\\n\",\n",
    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"def run_prompt(test_case):\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"Merges the prompt and test case input, then return the rsult\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"    prompt=f\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"    Please solve the following task:\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"    {test_case['task']}\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"    *Respond only with Python, JSON, or a plain Regex.\\\\n\\\",\\n\",\n",
    "    \"    \\\"    *Do not add any comments or commentary or explanations\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"    messages = []\\\\n\\\",\\n\",\n",
    "    \"    \\\"    add_user_message(messages, prompt)\\\\n\\\",\\n\",\n",
    "    \"    \\\"    add_assistant_message(messages, \\\\\\\"```code\\\\\\\")\\\\n\\\",\\n\",\n",
    "    \"    \\\"    output = chat(messages, stop_sequences=[\\\\\\\"```\\\\\\\"])\\\\n\\\",\\n\",\n",
    "    \"    \\\"    return output\\\"\\n\",\n",
    "    \"   ],\\n\",\n",
    "    \"   \\\"id\\\": \\\"6b3accdddf26a97\\\",\\n\",\n",
    "    \"   \\\"outputs\\\": [],\\n\",\n",
    "    \"   \\\"execution_count\\\": 20\\n\",\n",
    "    \"  },\\n\",\n",
    "    \"  {\\n\",\n",
    "    \"   \\\"metadata\\\": {},\\n\",\n",
    "    \"   \\\"cell_type\\\": \\\"code\\\",\\n\",\n",
    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"# Function to grade a test case + output using a model\\\\n\\\",\\n\",\n",
    "    \"    \\\"def grade_by_model(test_case, output):\\\\n\\\",\\n\",\n",
    "    \"    \\\"    eval_prompt = f\\\\\\\"\\\"\\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"You are an expert AWS code reviewer. Your task is to evaluate the following AI-generated solution.\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"Original Task:\\\\n\\\",\\n\",\n",
    "    \"    \\\"<task>\\\\n\\\",\\n\",\n",
    "    \"    \\\"{test_case[\\\\\\\"task\\\\\\\"]}\\\\n\\\",\\n\",\n",
    "    \"    \\\"</task>\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"Solution to Evaluate:\\\\n\\\",\\n\",\n",
    "    \"    \\\"<solution>\\\\n\\\",\\n\",\n",
    "    \"    \\\"{output}\\\\n\\\",\\n\",\n",
    "    \"    \\\"</solution>\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"Output Format\\\\n\\\",\\n\",\n",
    "    \"    \\\"Provide your evaluation as a structured JSON object with the following fields, in this specific order:\\\\n\\\",\\n\",\n",
    "    \"    \\\"- \\\\\\\"strengths\\\\\\\": An array of 1-3 key strengths\\\\n\\\",\\n\",\n",
    "    \"    \\\"- \\\\\\\"weaknesses\\\\\\\": An array of 1-3 key areas for improvement\\\\n\\\",\\n\",\n",
    "    \"    \\\"- \\\\\\\"reasoning\\\\\\\": A concise explanation of your overall assessment\\\\n\\\",\\n\",\n",
    "    \"    \\\"- \\\\\\\"score\\\\\\\": A number between 1-10\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"Respond with JSON. Keep your response concise and direct.\\\\n\\\",\\n\",\n",
    "    \"    \\\"Example response shape:\\\\n\\\",\\n\",\n",
    "    \"    \\\"{{\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"strengths\\\\\\\": string[],\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"weaknesses\\\\\\\": string[],\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"reasoning\\\\\\\": string,\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"score\\\\\\\": number\\\\n\\\",\\n\",\n",
    "    \"    \\\"}}\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\"\\\"\\\"\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"    messages = []\\\\n\\\",\\n\",\n",
    "    \"    \\\"    add_user_message(messages, eval_prompt)\\\\n\\\",\\n\",\n",
    "    \"    \\\"    add_assistant_message(messages, \\\\\\\"```json\\\\\\\")\\\\n\\\",\\n\",\n",
    "    \"    \\\"    eval_text = chat(messages, stop_sequences=[\\\\\\\"```\\\\\\\"])\\\\n\\\",\\n\",\n",
    "    \"    \\\"    return json.loads(eval_text)\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# Functions to validate the output structure\\\\n\\\",\\n\",\n",
    "    \"    \\\"import re\\\\n\\\",\\n\",\n",
    "    \"    \\\"import ast\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"def validate_json(text):\\\\n\\\",\\n\",\n",
    "    \"    \\\"    try:\\\\n\\\",\\n\",\n",
    "    \"    \\\"        json.loads(text.strip())\\\\n\\\",\\n\",\n",
    "    \"    \\\"        return 10\\\\n\\\",\\n\",\n",
    "    \"    \\\"    except json.JSONDecodeError:\\\\n\\\",\\n\",\n",
    "    \"    \\\"        return 0\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"def validate_python(text):\\\\n\\\",\\n\",\n",
    "    \"    \\\"    try:\\\\n\\\",\\n\",\n",
    "    \"    \\\"        ast.parse(text.strip())\\\\n\\\",\\n\",\n",
    "    \"    \\\"        return 10\\\\n\\\",\\n\",\n",
    "    \"    \\\"    except SyntaxError:\\\\n\\\",\\n\",\n",
    "    \"    \\\"        return 0\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"def validate_regex(text):\\\\n\\\",\\n\",\n",
    "    \"    \\\"    try:\\\\n\\\",\\n\",\n",
    "    \"    \\\"        re.compile(text.strip())\\\\n\\\",\\n\",\n",
    "    \"    \\\"        return 10\\\\n\\\",\\n\",\n",
    "    \"    \\\"    except re.error:\\\\n\\\",\\n\",\n",
    "    \"    \\\"        return 0\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"def grade_syntax(response, test_case):\\\\n\\\",\\n\",\n",
    "    \"    \\\"    format = test_case[\\\\\\\"format\\\\\\\"]\\\\n\\\",\\n\",\n",
    "    \"    \\\"    if format == \\\\\\\"json\\\\\\\":\\\\n\\\",\\n\",\n",
    "    \"    \\\"        return validate_json(response)\\\\n\\\",\\n\",\n",
    "    \"    \\\"    elif format == \\\\\\\"python\\\\\\\":\\\\n\\\",\\n\",\n",
    "    \"    \\\"        return validate_python(response)\\\\n\\\",\\n\",\n",
    "    \"    \\\"    else:\\\\n\\\",\\n\",\n",
    "    \"    \\\"        return validate_regex(response)\\\"\\n\",\n",
    "    \"   ],\\n\",\n",
    "    \"   \\\"id\\\": \\\"grading_functions\\\",\\n\",\n",
    "    \"   \\\"outputs\\\": [],\\n\",\n",
    "    \"   \\\"execution_count\\\": null\\n\",\n",
    "    \"  },\\n\",\n",
    "    \"  {\\n\",\n",
    "    \"   \\\"metadata\\\": {\\n\",\n",
    "    \"    \\\"ExecuteTime\\\": {\\n\",\n",
    "    \"     \\\"end_time\\\": \\\"2026-05-14T10:01:02.135948600Z\\\",\\n\",\n",
    "    \"     \\\"start_time\\\": \\\"2026-05-14T10:01:02.124324100Z\\\"\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"   },\\n\",\n",
    "    \"   \\\"cell_type\\\": \\\"code\\\",\\n\",\n",
    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"def run_test_case(test_case):\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"Calls run_prompt and then grades the result\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"    output = run_prompt(test_case)\\\\n\\\",\\n\",\n",
    "    \"    \\\"    model_grade = grade_by_model(test_case, output)\\\\n\\\",\\n\",\n",
    "    \"    \\\"    model_score = model_grade[\\\\\\\"score\\\\\\\"]\\\\n\\\",\\n\",\n",
    "    \"    \\\"    reasoning = model_grade[\\\\\\\"reasoning\\\\\\\"]\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"    syntax_score = grade_syntax(output, test_case)\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"    score = (model_score + syntax_score) / 2\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"    return{\\\\n\\\",\\n\",\n",
    "    \"    \\\"        \\\\\\\"output\\\\\\\": output,\\\\n\\\",\\n\",\n",
    "    \"    \"\n"
   ],
