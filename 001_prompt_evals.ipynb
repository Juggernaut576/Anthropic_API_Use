    "    \"    \\\"]\\\\n\\\",\\n\",\n",
    "    \"    \\\"```\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"* Focus on tasks that can be solved by writing a single Python function, a single JSON object, or a regular expression.\\\\n\\\",\\n\",\n",
    "    \"    \\\"* Focus on tasks that do not require writing much code\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"Please generate 3 objects.\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"    messages = []\\\\n\\\",\\n\",\n",
    "    \"    \\\"    add_user_message(messages, prompt)\\\\n\\\",\\n\",\n",
    "    \"    \\\"    add_assistant_message(messages, \\\\\\\"```json\\\\\\\")\\\\n\\\",\\n\",\n",
    "    \"    \\\"    text = chat(messages, stop_sequences=[\\\\\\\"```\\\\\\\"])\\\\n\\\",\\n\",\n",
