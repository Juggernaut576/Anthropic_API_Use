    "    \"    \\\"    prompt = \\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"Generate a evaluation dataset for a prompt evaluation. The dataset will be used to evaluate prompts\\\\n\\\",\\n\",\n",
    "    \"    \\\"that generate Python, JSON, or Regex specifically for AWS-related tasks. Generate an array of JSON objects,\\\\n\\\",\\n\",\n",
    "    \"    \\\"each representing task that requires Python, JSON, or a Regex to complete.\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"Example output:\\\\n\\\",\\n\",\n",
    "    \"    \\\"```json\\\\n\\\",\\n\",\n",
    "    \"    \\\"[\\\\n\\\",\\n\",\n",
    "    \"    \\\"    {\\\\n\\\",\\n\",\n",
    "    \"    \\\"        \\\\\\\"task\\\\\\\": \\\\\\\"Description of task\\\\\\\",\\\\n\\\",\\n\",\n",
