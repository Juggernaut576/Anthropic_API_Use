    "    \"    \\\"from unittest import result\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"from debugpy.launcher import output\\\\n\\\",\\n\",\n",
