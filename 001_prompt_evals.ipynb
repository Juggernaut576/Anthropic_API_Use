    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"# Helper functions\\\\n\\\",\\n\",\n",
    "    \"    \\\"def add_user_message(messages, text):\\\\n\\\",\\n\",\n",
    "    \"    \\\"    user_message = {\\\\\\\"role\\\\\\\": \\\\\\\"user\\\\\\\", \\\\\\\"content\\\\\\\": text}\\\\n\\\",\\n\",\n",
    "    \"    \\\"    messages.append(user_message)\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"def add_assistant_message(messages, text):\\\\n\\\",\\n\",\n",
    "    \"    \\\"    assistant_message = {\\\\\\\"role\\\\\\\": \\\\\\\"assistant\\\\\\\", \\\\\\\"content\\\\\\\": text}\\\\n\\\",\\n\",\n",
    "    \"    \\\"    messages.append(assistant_message)\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"def chat(messages, system=None, temperature=1.0, stop_sequences=[]):\\\\n\\\",\\n\",\n",
    "    \"    \\\"    params = {\\\\n\\\",\\n\",\n",
    "    \"    \\\"        \\\\\\\"model\\\\\\\": model,\\\\n\\\",\\n\",\n",
    "    \"    \\\"        \\\\\\\"max_tokens\\\\\\\": 1000,\\\\n\\\",\\n\",\n",
    "    \"    \\\"        \\\\\\\"messages\\\\\\\": messages,\\\\n\\\",\\n\",\n",
    "    \"    \\\"        \\\\\\\"temperature\\\\\\\": temperature,\\\\n\\\",\\n\",\n",
    "    \"    \\\"        \\\\\\\"stop_sequences\\\\\\\": stop_sequences,\\\\n\\\",\\n\",\n",
    "    \"    \\\"    }\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"    if system:\\\\n\\\",\\n\",\n",
    "    \"    \\\"        params[\\\\\\\"system\\\\\\\"] = system\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"    message = client.messages.create(**params)\\\\n\\\",\\n\",\n",
    "    \"    \\\"    return message.content[0].text\\\"\\n\",\n",
